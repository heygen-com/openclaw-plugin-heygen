{
  "name": "openclaw-plugin-heygen",
  "version": "0.1.0",
  "description": "HeyGen Video Agent provider plugin for OpenClaw — first-class avatar/presenter video generation via OpenClaw's video_generate tool.",
  "type": "module",
  "license": "MIT",
  "author": "HeyGen <support@heygen.com>",
  "homepage": "https://github.com/heygen-com/openclaw-plugin-heygen#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/heygen-com/openclaw-plugin-heygen.git"
  },
  "bugs": {
    "url": "https://github.com/heygen-com/openclaw-plugin-heygen/issues"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "heygen",
    "video",
    "avatar",
    "video-agent",
    "ai-video",
    "video-generation"
  ],
  "files": [
    "index.ts",
    "video-generation-provider.ts",
    "openclaw.plugin.json",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.24-beta.2"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": false
    }
  },
  "openclaw": {
    "extensions": ["./index.ts"],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.4.22",
      "pluginSdkVersion": "2026.4.22"
    }
  }
}
